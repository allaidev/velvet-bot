# ─── Telegram ───────────────────────────────────────────────────────────────────
# Get the token from @BotFather → /newbot
BOT_TOKEN=123456:replace-me

# Numeric ID of the private channel the bot will guard.
# Forward any message from your channel to @userinfobot to find it (starts with -100).
# The bot MUST be added to the channel as an administrator with "Invite users via link" permission.
CHANNEL_ID=-1001234567890

# Comma-separated Telegram user IDs that can open the admin panel.
# Send /start to @userinfobot to find your own ID.
ADMIN_IDS=111111111,222222222

# Optional public @username of the channel (used in messages only). Leave empty if private.
CHANNEL_USERNAME=

# ─── CryptoBot (Crypto Pay) ─────────────────────────────────────────────────────
# Token from @CryptoBot → Crypto Pay → My Apps → Create App
# For testnet use @CryptoTestnetBot instead and set CRYPTO_PAY_BASE_URL below.
CRYPTO_PAY_TOKEN=replace-me

# Use "https://pay.crypt.bot" for mainnet or "https://testnet-pay.crypt.bot" for testnet.
CRYPTO_PAY_BASE_URL=https://pay.crypt.bot

# Currencies offered to the buyer. Supported: USDT, TON, BTC, ETH, etc.
CRYPTO_PAY_ASSETS=USDT,TON

# ─── Webhook (optional, recommended in production) ──────────────────────────────
# If WEBHOOK_ENABLED=true, the bot starts an aiohttp server for Crypto Pay webhooks.
# Otherwise payments are reconciled by polling every POLL_INTERVAL_SECONDS seconds.
WEBHOOK_ENABLED=false
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/cryptopay
POLL_INTERVAL_SECONDS=60

# ─── Subscription plans ─────────────────────────────────────────────────────────
# JSON list — must be on ONE LINE (no line breaks inside the value).
# "id" must be unique and stable — it is stored alongside every payment.
# "price" is in the asset chosen by the user at checkout.
SUBSCRIPTION_PLANS=[{"id":"1m","title":"1 Month","days":30,"price":"5.00"},{"id":"3m","title":"3 Months","days":90,"price":"13.00"},{"id":"6m","title":"6 Months","days":180,"price":"24.00"},{"id":"12m","title":"12 Months","days":365,"price":"42.00"}]

# How many days before expiry to send a renewal reminder. Comma-separated.
REMINDER_DAYS=3,1

# ─── Branding ───────────────────────────────────────────────────────────────────
# Path to the welcome image shown with /start. Leave empty to skip.
WELCOME_IMAGE=assets/welcome.jpg
SUPPORT_URL=https://t.me/your_support
INFO_URL=

# ─── Storage ────────────────────────────────────────────────────────────────────
# SQLite by default — the file is created automatically. For production PostgreSQL:
#   postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///data/bot.sqlite3

# ─── Misc ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Anti-abuse: max number of buy attempts per minute per user.
THROTTLE_BUY_PER_MINUTE=5
